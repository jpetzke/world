# Weltmodell — Deployment-Konfiguration (Coolify: als Environment Variables setzen).
# NICHT committen. Werte hier sind Platzhalter.

# --- Auth (Single-User) ------------------------------------------------------
AUTH_USERNAME=admin
# Starkes Passwort wählen (z. B. `openssl rand -base64 24`).
AUTH_PASSWORD=change-me-strong-password

# --- Session-Signierung ------------------------------------------------------
# Pflicht in Prod. Erzeugen: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-long-random-secret

# --- Betriebsmodus -----------------------------------------------------------
# production => Secure-Cookies, HSTS, /docs aus, kein Dev-CORS.
WELTMODELL_ENV=production

# --- Datenbank (vom docker-compose zusammengesetzt) --------------------------
POSTGRES_USER=weltmodell
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=weltmodell
# WELTMODELL_DSN wird im compose aus obigen Werten gebaut — nur überschreiben,
# wenn du eine externe DB nutzt.

# --- LLM-Extraktor (optional) ------------------------------------------------
OPENROUTER_API_KEY=
WELTMODELL_LLM_MODEL=poolside/laguna-xs-2.1:free
